{
    "GUI": {
        "node_name_mode": 1,
        "default_node_name": "<add_node_name>",
        "node_size_unlimited": true,
        "port_size": 50,
        "pipe_style": 2,
        "pipe_width": 10,
        "white_background": true,
        "main_window_size": [
            1046,
            748
        ],
        "state": "",
        "open_session_in_same_ddt": true,
        "recent_files": []
    },
    "BUILD": {
        "DDT_WORK_ROOT": null,
        "parent_var_name": "B",
        "record_step": "ddt_history.log",
        "library": [],
        "library_path": "",
        "use_config_lib_path": true,
        "file_rename_mode": 2
